# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (not recommended for production).
ALLOWED_ORIGINS=https://your-site.com

# ── Discord ───────────────────────────────────────────────────────────────────
# Leave empty to disable the Discord notifier.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANNEL_ID/TOKEN

# ── Slack ─────────────────────────────────────────────────────────────────────
# Leave empty to disable the Slack notifier.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/XXXX

# ── Telegram ──────────────────────────────────────────────────────────────────
# Leave both empty to disable the Telegram notifier.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# ── PostgreSQL (feedback feature) ────────────────────────────────────────────
# Leave empty to disable the feedback feature entirely.
DATABASE_URL=postgres://user:pass@localhost:5432/forwarder?sslmode=disable
