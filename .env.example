# HTTP server port (default: 8080)
PORT=8080

# Comma-separated list of origins allowed to call the API.
# Use * to allow any origin (not recommended for production).
ALLOWED_ORIGINS=https://your-site.com,https://other-site.com

# Telegram – remove or leave empty to disable.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# Discord – remove or leave empty to disable.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# PostgreSQL connection string (required for the feedback feature).
DATABASE_URL=postgres://user:password@localhost:5432/formresponse?sslmode=disable
